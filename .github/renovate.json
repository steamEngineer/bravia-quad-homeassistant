{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": ["before 2am"],
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "labels": ["dependencies", "no-stale"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "commitMessagePrefix": "⬆️",
  "customManagers": [
    {
      "customType": "regex",
      "description": "uv python install pins in GitHub Actions workflows",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/.*\\.ya?ml$/"],
      "matchStrings": [
        "run: uv python install (?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "python-version",
      "depNameTemplate": "python",
      "versioningTemplate": "python"
    }
  ],
  "packageRules": [
    {
      "description": "Group .python-version and CI uv python install pins in one PR",
      "matchDepNames": ["python"],
      "groupName": "python"
    },
    {
      "description": "Keep pyproject requires-python at the HA minimum; bump manually",
      "matchManagers": ["pep621"],
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "matchManagers": ["pep621"],
      "addLabels": ["python"]
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dev"],
      "rangeStrategy": "pin"
    },
    {
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchManagers": ["pep621"],
      "matchPackageNames": ["homeassistant"],
      "enabled": false
    },
    {
      "matchManagers": ["pep621"],
      "matchPackageNames": ["aiohttp"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["github_actions"],
      "rangeStrategy": "pin"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
